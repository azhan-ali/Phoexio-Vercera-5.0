# Copy this file to .env.local and fill in your Grok API key
GROK_API_KEY=your_grok_api_key_here
GROK_API_BASE_URL=https://api.x.ai/v1
# Language model (also handles vision since all modern Grok models accept images)
GROK_TEXT_MODEL=grok-4-1-fast-non-reasoning
# Override only if you want a different model for image-in calls
GROK_VISION_MODEL=grok-4-1-fast-non-reasoning
# Image generation model (use grok-imagine-image-pro for higher quality)
GROK_IMAGE_MODEL=grok-imagine-image
